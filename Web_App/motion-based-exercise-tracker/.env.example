# Copy this file to `.env` and fill in values from your Firebase project.
# Do NOT commit your `.env` (add to .gitignore).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Where to get these values:
# 1. Open https://console.firebase.google.com/ and select your project.
# 2. Go to Project settings (gear icon  Project settings)  "Your apps".
#    - If you don't have a web app, click "Add app"  choose Web and register it.
#    - In the SDK configuration (Firebase SDK snippet) you'll see the config object values
#      (apiKey, authDomain, projectId, storageBucket, messagingSenderId, appId).
# 3. `databaseURL` (Realtime Database) is shown in the Realtime Database section
#    (Console  Build  Realtime Database) as the database endpoint URL.
#    Use that URL for VITE_FIREBASE_DATABASE_URL.
# Notes:
# - This project uses the Realtime Database (`getDatabase`), so ensure your Realtime Database
#   is enabled and you use the Realtime Database URL.
# - Vite requires env vars that should be prefixed with "VITE_" to be exposed to the client.
# - After creating `.env`, restart the dev server to pick up new env vars.
